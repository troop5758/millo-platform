# Domain binding — Phase 0 Confirmation
# Production must use https://milloapp.com
# Copy to .env or inject into deployment; never commit real secrets.

# Base URL (production)
PUBLIC_APP_URL=https://milloapp.com
API_BASE_URL=https://milloapp.com
NEXT_PUBLIC_APP_URL=https://milloapp.com

# Optional: separate API subdomain (if used later)
# API_BASE_URL=https://api.milloapp.com

# CORS (allow production domain)
ALLOWED_ORIGINS=https://milloapp.com,https://www.milloapp.com
