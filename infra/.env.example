# Millo 3.0 — Environment. Copy to repo root .env. https://milloapp.com
NODE_ENV=production
MILLO_APP_URL=https://milloapp.com
# Minimum production stack: MongoDB (or LEDGER_PG_URI for ledger), Redis, Stripe (+ webhook secret),
# S3 (AWS_S3_BUCKET + credentials), Kafka or queue workers (KAFKA_BROKERS / BullMQ as deployed).
MONGODB_URI=mongodb://localhost:27017/millo
# Optional: PostgreSQL ledger
# LEDGER_PG_URI=postgresql://millo@localhost:5432/millo_ledger
REDIS_URI=redis://localhost:6379
# API code reads REDIS_URL; set to same as REDIS_URI or use REDIS_HOST + REDIS_PORT
REDIS_URL=redis://localhost:6379
# S3 / CDN (see infra/s3-binding.sh)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=millo-cdn
# CDN_BASE_URL=https://cdn.milloapp.com
# OAuth (optional; 501 until set)
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_FACEBOOK_CLIENT_ID=
# OAUTH_APPLE_CLIENT_ID=
# APP_URL=https://milloapp.com
# Kill-switches (with NODE_ENV=production: AI optimization ON unless AI_OPTIMIZATION_ENABLED=false)
# In development, set AI_OPTIMIZATION_ENABLED=true to enable ranking/ads AI hooks locally.
# ADS_ENABLED=false          # set to halt all ad delivery
# AI_OPTIMIZATION_ENABLED=false  # emergency: disables AI ranking bump + ads AI + suggest* APIs
# AI_SHADOW_MODE=true        # advisory-only: no ranking/ads injection (suggest* still logs)
# AI_RANKING_INJECTION_ENABLED=false
# AI_ADS_OPTIMIZATION_ENABLED=false
# AI_RANK_SCORE_WEIGHT=0.3   # discovery score += aiScore * weight (or heuristic * weight)
# MILLA_ENABLED=false
