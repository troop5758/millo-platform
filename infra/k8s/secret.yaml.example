# Copy to secret.yaml and fill values. Do NOT commit secret.yaml.
# kubectl create secret generic millo-secrets --from-env-file=.env --dry-run=client -o yaml
apiVersion: v1
kind: Secret
metadata:
  name: millo-secrets
  namespace: millo
type: Opaque
stringData:
  MONGO_URI: "<mongodb-connection-string>"
  REDIS_URL: "redis://redis:6379"
  STRIPE_SECRET_KEY: "<stripe-secret>"
  JWT_SECRET: "<jwt-secret>"
  INGEST_WEBHOOK_SECRET: "<ingest-webhook-secret>"
