FROM tiangolo/nginx-rtmp

# Copy nginx config with RTMP and HLS settings
COPY nginx.conf /etc/nginx/nginx.conf

# Install curl for on_publish/on_done webhooks
RUN apt-get update -qq && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

# HLS output directory
RUN mkdir -p /tmp/hls /recordings

EXPOSE 1935 80
