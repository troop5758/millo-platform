# ─────────────────────────────────────────────────────────────────────────────
# Millo — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# Run `npm run env:validate` at any time to verify your configuration.
# https://milloapp.com
# ─────────────────────────────────────────────────────────────────────────────

# ─── Required ────────────────────────────────────────────────────────────────

# MongoDB connection string (Atlas or self-hosted)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/millo

# Secrets — use strong random values in production (32+ chars)
SESSION_SECRET=CHANGE_ME_use_a_long_random_string_here
JWT_SECRET=CHANGE_ME_use_a_different_long_random_string

# URLs
FRONTEND_URL=https://milloapp.com
APP_URL=https://api.milloapp.com
CORS_ORIGIN=https://milloapp.com

# ─── Payments (Stripe) ────────────────────────────────────────────────────────
# Required for the payments feature to function.
STRIPE_SECRET=
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Phase 5 Creator Monetization ────────────────────────────────────────────────
# Stripe Connect (creator payouts)
STRIPE_CONNECT_DEFAULT_COUNTRY=US
# Production Truth Layer: payouts are LIVE only when Stripe is configured and STRIPE_PAYOUTS=true (see config/production-truth.js)
STRIPE_PAYOUTS=
# PayPal Payouts & Webhooks
PAYPAL_CLIENT=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# Set PAYPAL_SANDBOX=true for sandbox (api-m.sandbox.paypal.com)
PAYPAL_SANDBOX=
# Wise (international payouts)
WISE_API_KEY=
WISE_API_TOKEN=
# KYC: onfido | persona | stripe_identity
KYC_PROVIDER=stripe_identity
ONFIDO_API_TOKEN=
ONFIDO_REGION=eu

# ─── Tax & VAT (Phase 4) ──────────────────────────────────────────────────────
# TAX_PROVIDER: avalara | taxjar | stripe | fallback (default: fallback)
TAX_PROVIDER=fallback
# Avalara (when TAX_PROVIDER=avalara)
AVALARA_USERNAME=
AVALARA_PASSWORD=
AVALARA_ENV=sandbox
# TaxJar (when TAX_PROVIDER=taxjar)
TAXJAR_API_KEY=

# ─── Email (@millo/notifications) ───────────────────────────────────────────
# API requires EMAIL_PROVIDER: sendgrid | aws_ses | resend | smtp | console
# Use console for local/dev (emails logged, not sent). Production: use a real provider (not console).
# Sandboxes only: EMAIL_ALLOW_CONSOLE_IN_PRODUCTION=true
EMAIL_PROVIDER=console
SMTP_KEY=
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@milloapp.com
# E2E / ops: POST /internal/test-email (or /api/internal/test-email) with header X-Internal-Probe-Key
INTERNAL_EMAIL_PROBE_SECRET=

# ─── OAuth Providers ──────────────────────────────────────────────────────────
# Optional — enables social login buttons
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
# OAUTH_APPLE_PRIVATE_KEY — base64-encoded .p8 key file contents
OAUTH_APPLE_PRIVATE_KEY=

# ─── Live Streaming (Cloudflare Stream) ───────────────────────────────────────
# Optional — required for live streaming features
CLOUDFLARE_STREAM_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Janus WebRTC — when set, GET /api/live/status returns webrtc: LIVE
# JANUS_URL=https://janus.milloapp.com/janus
# JANUS_GATEWAY_URL=
# Real-time filters — default stubbed; set true only when client/server filter pipeline is verified LIVE
LIVE_FILTERS_LIVE=false

# ─── AI (Milla) ───────────────────────────────────────────────────────────────
# AI shadow-mode stays off unless MILLA_ENABLED=true is also set
MILLA_API_KEY=
MILLA_ENABLED=false

# ─── Voice (TTS/STT) ──────────────────────────────────────────────────────────
# Off by default; enable with VOICE_TTS_ENABLED=true
OPENAI_API_KEY=
VOICE_TTS_ENABLED=false

# ─── AI Moderation ────────────────────────────────────────────────────────────
# Off by default; enable with AI_MODERATION_ENABLED=true (uses OPENAI_API_KEY)
AI_MODERATION_ENABLED=false

# ─── Live stream bot detection ─────────────────────────────────────────────────
# When viewer join rate or other signals exceed thresholds, stream is flagged (FraudEvent).
# LIVE_BOT_JOIN_RATE_THRESHOLD=120
# LIVE_BOT_JOIN_WINDOW_MS=60000
# LIVE_BOT_ZERO_WATCH_SEC=5
# LIVE_BOT_ZERO_WATCH_RATIO=0.7
# LIVE_BOT_IDENTICAL_JOIN_THRESHOLD=25
# LIVE_BOT_CHAT_SPAM_MSGS=15

# ─── CAPTCHA (high-risk challenge) ─────────────────────────────────────────────
# When risk score > CAPTCHA_THRESHOLD (default 70), require CAPTCHA. Provider: turnstile | hcaptcha | arkose
# CAPTCHA_PROVIDER=turnstile
# CAPTCHA_THRESHOLD=70
# Cloudflare Turnstile
# CLOUDFLARE_TURNSTILE_SITE_KEY=
# CLOUDFLARE_TURNSTILE_SECRET_KEY=
# hCaptcha
# HCAPTCHA_SITE_KEY=
# HCAPTCHA_SECRET_KEY=
# Arkose Labs
# ARKOSE_PUBLIC_KEY=
# ARKOSE_PRIVATE_KEY=

# ─── Bot detection enforcement pipeline (BullMQ) ───────────────────────────────
# Thresholds for automated actions after risk_score_update job
# BOT_ENFORCE_CAPTCHA_THRESHOLD=70
# BOT_ENFORCE_SHADOW_BAN_THRESHOLD=80
# BOT_ENFORCE_PERMANENT_BAN_THRESHOLD=95
# TTL (seconds) for require_captcha Redis key (default 24h)
# BOT_REQUIRE_CAPTCHA_TTL_SEC=86400

# ─── Copyright / DMCA (designated agent — required for safe harbor) ─────────────
# Set these in production. Optionally register the agent at copyright.gov/dmca-directory.
DMCA_AGENT_NAME=Copyright Agent
DMCA_AGENT_ADDRESS=Your Company, 123 Street, City, State ZIP
DMCA_AGENT_EMAIL=dmca@milloapp.com
# After this many valid takedowns, user may be treated as repeat infringer (default 3)
DMCA_REPEAT_INFRINGER_THRESHOLD=3

# ─── Installation (first run only) ────────────────────────────────────────────
# Temporary admin credentials. Used only when no admin user exists; create one then change password in Admin → Account.
INITIAL_ADMIN_EMAIL=admin@milloapp.com
INITIAL_ADMIN_PASSWORD=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# ─── Observability ─────────────────────────────────────────────────────────────
# Sentry DSN for error tracking. API uses SENTRY_DSN; web uses VITE_SENTRY_DSN (build-time).
SENTRY_DSN=
VITE_SENTRY_DSN=
# Optional: release version for Sentry
APP_VERSION=3.0.0
GIT_COMMIT=
BUILD_DATE=
VITE_APP_VERSION=3.0.0
# Log aggregation — Winston; optional Loki (Grafana) or ELK (Elasticsearch)
# LOG_LEVEL=info (default)
# Loki: LOG_LOKI_ENABLED=true, LOG_LOKI_HOST=http://127.0.0.1:3100 (or LOKI_HOST)
# ELK: LOG_ELASTIC_ENABLED=true, LOG_ELASTIC_NODE=http://localhost:9200 (or ELASTICSEARCH_NODE)
# LOG_ELASTIC_INDEX_PREFIX=millo-api
# LOG_ELASTIC_USERNAME=, LOG_ELASTIC_PASSWORD= (optional)
LOG_LOKI_ENABLED=false
LOG_LOKI_HOST=
LOG_ELASTIC_ENABLED=false
LOG_ELASTIC_NODE=

# ─── Security ─────────────────────────────────────────────────────────────────
# Set to true in production — HSTS, secure cookies, etc.
SECURE_COOKIES=true
# Login alerts: email user on new device or new location (session registry)
# LOGIN_ALERT_EMAIL_ENABLED=false
# Disallow console-only email transport in production (health check will report misconfigured)
EMAIL_CONSOLE_DISALLOWED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
# Infra hardening: disable root SSH login during deploy script
DISABLE_ROOT_LOGIN=false

# ─── CDN / Storage ────────────────────────────────────────────────────────────
# Optional — for serving uploaded assets via CDN
CDN_BASE_URL=https://cdn.milloapp.com
# Audio CDN — music files at e.g. cdn.milloapp.com/music/trk_9981.mp3 (fallback: CDN_BASE_URL)
AUDIO_CDN_URL=https://cdn.milloapp.com
# Provider for music uploads: s3 | r2 | gcs (default: s3)
AUDIO_CDN_PROVIDER=s3
# Bucket for music (default: UPLOAD_BUCKET or millo-music)
AUDIO_CDN_BUCKET=millo-music
# S3: use AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION (or AUDIO_CDN_ACCESS_KEY_ID, AUDIO_CDN_SECRET_ACCESS_KEY, AUDIO_CDN_REGION)
# R2: R2_ACCOUNT_ID (or CLOUDFLARE_ACCOUNT_ID), R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY, R2_BUCKET_NAME
# GCS: GCS_PROJECT_ID (or GOOGLE_CLOUD_PROJECT), GOOGLE_APPLICATION_CREDENTIALS (or GCS_KEY_FILE), GCS_BUCKET
# Audio fingerprint / copyright protection (block upload if copyrighted music detected)
AUDIO_COPYRIGHT_PROVIDER=
AUDIO_COPYRIGHT_ACTION=block
# AudD: AUDD_API_TOKEN (https://dashboard.audd.io/)
# ACRCloud: ACRCLOUD_ACCESS_KEY, ACRCLOUD_ACCESS_SECRET, ACRCLOUD_HOST (e.g. identify-eu-west-1.acrcloud.com)
# Pex: PEX_API_KEY
# Audio moderation (hate speech, adult) — OpenAI Whisper+Moderation, Hive AI, AssemblyAI content_safety
AI_AUDIO_MODERATION_ENABLED=false
AUDIO_MODERATION_BLOCK_THRESHOLD=0.7
AUDIO_MODERATION_REVIEW_THRESHOLD=0.4
# OpenAI: OPENAI_API_KEY (Whisper transcribe + Moderation API on transcript)
# Hive: HIVE_API_KEY, optional HIVE_API_URL (default https://api.thehive.ai/api/v2/task/sync)
# AssemblyAI: ASSEMBLYAI_API_KEY, optional ASSEMBLYAI_BASE_URL (default https://api.assemblyai.com)
# Creator Music Upload Program — artist rev share (default 70%), license version for signup
ARTIST_REV_SHARE_PERCENT=70
ARTIST_LICENSE_VERSION=1
# Viral Sound Engine — weight for boosting feed by sound viral score (default 0.15)
VIRAL_SOUND_BOOST_WEIGHT=0.15
# Sound saturation — max share of feed (0–1) any single sound can occupy; prevents feed monotony (default 8%)
MAX_FEED_SHARE_PER_SOUND=0.08
# Creator diversity — minimum unique creators using a sound for trending/viral (prevents one creator from gaming)
CREATOR_DIVERSITY_MIN=20
# Watch-time boost — minimum completion rate (0–1) for sound exposure; TikTok heavily weights completion (default 0.7 = 70%)
COMPLETION_RATE_MIN=0.7
# Sound loop behavior — loop_rate = total_plays / total_views; > LOOP_RATE_THRESHOLD (default 1.2) massively boosts ranking
LOOP_RATE_THRESHOLD=1.2
LOOP_RATE_BOOST_WEIGHT=80
LOOP_RATE_BOOST_EARLY=0.25
# Sound seeding — internal flag seed_priority; algorithm boosts early uses (platform partners, popular creators, brand campaigns)
SEED_PRIORITY_BOOST=100
SEED_PRIORITY_BOOST_EARLY=0.15
# Anti-gaming — sounds with fraud_score >= this are removed from trending and viral candidates (bot views, same IP, coordinated accounts, rapid reuse)
SOUND_FRAUD_THRESHOLD=60
# Cross-cluster propagation — top % of sounds in a cluster to test in other clusters (default 20)
CLUSTER_TOP_PERCENT_FOR_EXPANSION=20
# Early Viral Detection — first N videos per sound; if signals exceed threshold, sound enters viral_sound_candidates
EARLY_VIRAL_WINDOW_MIN=50
EARLY_VIRAL_WINDOW_MAX=500
EARLY_VIRAL_THRESHOLD=0.45
# Video+audio composition (FFmpeg worker): output dir and optional base URL for composed files
COMPOSED_MEDIA_DIR=
COMPOSED_MEDIA_BASE_URL=
UPLOAD_BUCKET=millo-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
