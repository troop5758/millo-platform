; Millo monorepo — npm config
;
; IMPORTANT (Windows): npm ALWAYS symlinks workspace packages into node_modules.
; `install-links=false` does NOT disable workspace symlinks (see @npmcli/arborist
; build-ideal-tree: shouldLink = isWorkspace || …). It only affects some file:
; dependencies outside the workspace rules.
;
; If you see: EISDIR symlink → packages\ppv → node_modules\@millo\ppv
; use docs/WINDOWS-WORKSPACE-INSTALL.md (Developer Mode, WSL, or pnpm).
install-links=false
