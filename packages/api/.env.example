# =============================================================================
# Millo API — environment template
# Copy to .env (or use your host's secret store). NEVER commit real .env.
# Aligned with: packages/api/src/bootstrap/validateEnv.js, productionGuard, providerState
# Docs: docs/ENV-SETUP-GUIDE.md, docs/SETUP-PRODUCTION.md
# =============================================================================

# -----------------------------------------------------------------------------
# BOOTSTRAP ADMIN (optional — only when zero admins in DB)
# Prefer: npm run bootstrap:admin (install script) — avoids leaving password in .env
# -----------------------------------------------------------------------------
# INITIAL_ADMIN_EMAIL=admin@milloapp.com
# INITIAL_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# CORE — REQUIRED FOR PRODUCTION (validateEnv critical + typical boot)
# -----------------------------------------------------------------------------
NODE_ENV=development
# REQUIRED FOR PRODUCTION
MONGODB_URI=mongodb://127.0.0.1:27017/millo
# REQUIRED FOR PRODUCTION (or configure REDIS_HOST/REDIS_PORT where supported)
REDIS_URL=redis://127.0.0.1:6379
# REQUIRED FOR PRODUCTION — min 32 characters in production
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_FOR_PRODUCTION________________

# Public URLs — REQUIRED FOR PRODUCTION (correct links, CORS, redirects)
FRONTEND_URL=https://milloapp.com
CORS_ORIGIN=https://milloapp.com
# OPTIONAL — some routes fall back to FRONTEND_URL
# APP_URL=https://milloapp.com

# REQUIRED FOR PRODUCTION — must not be sandbox/dev/coin as primary (productionGuard)
PAYMENT_PROVIDER=stripe

# -----------------------------------------------------------------------------
# AUTH — OAuth (packages/api/src/services/oauthProviders.js)
# REQUIRED FOR PRODUCTION — at least one OAuth provider enabled (productionGuard)
# -----------------------------------------------------------------------------
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_TWITTER_CLIENT_ID=
OAUTH_TWITTER_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# OPTIONAL — health snapshot getOAuthState() reads these for Google/Facebook/Apple
# If unset, /health oauth.google may show unconfigured while OAUTH_GOOGLE_* still works
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=

# -----------------------------------------------------------------------------
# PAYMENTS — Stripe / PayPal / Wise
# REQUIRED FOR PRODUCTION (validateEnv): STRIPE_* if Stripe is live
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# STRONGLY RECOMMENDED for webhooks
STRIPE_WEBHOOK_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
WISE_API_TOKEN=

# OPTIONAL
# WALLET_CREDIT_LOCK_MS=15000

# -----------------------------------------------------------------------------
# EMAIL — @millo/notifications (EMAIL_PROVIDER required; API throws "Email system not configured" if unset)
# REQUIRED FOR PRODUCTION: real provider + credentials (not console for customers)
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=console
# STUB MODE IF MISSING / console — emails log only
# Set to: sendgrid | aws_ses | resend | smtp

SENDGRID_API_KEY=
# OPTIONAL alias used by some paths
# SENDGRID_KEY=

# If EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# If EMAIL_PROVIDER=aws_ses
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SES_REGION=us-east-1

# If EMAIL_PROVIDER=resend
# RESEND_API_KEY=

# PRODUCTION: console email is rejected by default (customer mail would not be delivered).
# Set only for non-customer sandboxes:
# EMAIL_ALLOW_CONSOLE_IN_PRODUCTION=true

# -----------------------------------------------------------------------------
# PUSH — packages/notifications/src/push.js
# OPTIONAL — only if push in launch scope
# -----------------------------------------------------------------------------
FIREBASE_SERVER_KEY=
EXPO_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# SAFETY / TRUST
# -----------------------------------------------------------------------------
# AI moderation: disabled unless AI_MODERATION_ENABLED=true
AI_MODERATION_ENABLED=false
OPENAI_API_KEY=
HIVE_API_KEY=

KYC_PROVIDER=
ONFIDO_API_TOKEN=
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=

CLOUDFLARE_IP_REPUTATION_ENABLED=false
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

CAPTCHA_PROVIDER=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
CLOUDFLARE_TURNSTILE_SITE_KEY=
# Alias for Turnstile secret (captchaService accepts either)
# TURNSTILE_SECRET=

# Login RBA — lockout after failed passwords (userSecurity.service.js)
# LOGIN_LOCK_FAILED_ATTEMPTS=5
# LOGIN_LOCK_DURATION_MS=600000

# Login step-up OTP TTL (seconds; otp.service.js)
# LOGIN_OTP_TTL_SEC=300

# Reverse proxy / load balancer — correct client IP for RBA, rate limits, ATO (Fastify trustProxy)
# TRUST_PROXY=true
# BEHIND_PROXY=true

# Stricter startup checks: APP_URL must be https, warn if CORS_ORIGIN omits milloapp.com
# ENTERPRISE_BOOT_STRICT=true

# Ops probes: GET /health/live (process only), GET /health/ready (Mongo ping), GET /health (full dashboard)

# Logging (Fastify / Pino). Default: info in production, debug otherwise. Sensitive headers redacted in logs.
# LOG_LEVEL=info

# Device fingerprint zero-trust (optional)
# ZERO_TRUST_DEVICE_FINGERPRINT=true

# OPTIONAL — Sift Events API v205 ($transaction on payment intent, $login on new session). Use with web VITE_SIFT_BEACON_KEY.
# SIFT_API_KEY=

# OPTIONAL — login risk pipeline (loginRiskDecision.service.js) + RBA (loginRba.service.js / riskEngine.service.js)
# LOGIN_HARD_BLOCK_COMBINED_THRESHOLD=96
# LOGIN_STEP_UP_COMBINED_THRESHOLD=50
# LOGIN_STEP_UP_ENGINE_THRESHOLD=58

# OPTIONAL — behavior batch enforcement (see behaviorEnforcement.service.js, botDetection.service.js)
# BEHAVIOR_CAPTCHA_TOTAL_THRESHOLD=50
# BEHAVIOR_TRUST_EDGE_THRESHOLD=45
# BEHAVIOR_RESTRICT_TOTAL_THRESHOLD=80
# BEHAVIOR_HTTP_CAPTCHA_403=false
# CAPTCHA_PROVIDER=turnstile
# CLOUDFLARE_TURNSTILE_SITE_KEY=
# CLOUDFLARE_TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# INFRA / OPTIONAL — NOT LAUNCH PREREQUISITES (per Millo docs)
# -----------------------------------------------------------------------------
# KAFKA_BROKERS=   # validateEnv may warn if missing; not required for narrow launch

# Live / media (tune per deployment)
# HLS_HOST=hls.milloapp.com
# RTMP_INGEST_HOST=ingest.milloapp.com
# INGEST_WEBHOOK_SECRET=

# S3 / R2 (content, moderation uploads, etc.)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=

# Ops
# SENTRY_DSN=
# OPTIONAL — with providerStatus.middleware + registerProviderStatusHeaderHook
# ATTACH_PROVIDER_STATUS_HEADER=true
# DISABLE_RATE_LIMIT=false
# SKIP_AUTH must not be true in production
# DEV_MODE / DEVELOPMENT must not be true in production

# App metadata
# APP_VERSION=3.0.0
# GIT_COMMIT=
# BUILD_DATE=
