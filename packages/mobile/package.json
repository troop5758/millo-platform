{
  "name": "@millo/mobile",
  "version": "1.0.0",
  "description": "Millo — mobile app (Expo / React Native)",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "test": "jest --passWithNoTests"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "transform": {
      "^.+\\.jsx?$": [
        "babel-jest",
        {
          "presets": [
            "@babel/preset-env",
            "@babel/preset-react"
          ]
        }
      ]
    },
    "moduleNameMapper": {
      "^expo-secure-store$": "<rootDir>/src/__mocks__/expo-secure-store.js",
      "^expo-constants$": "<rootDir>/src/__mocks__/expo-constants.js",
      "^react-native$": "<rootDir>/src/__mocks__/react-native.js",
      "^react-native-video$": "<rootDir>/src/__mocks__/react-native-video.js",
      "^react-i18next$": "<rootDir>/src/__mocks__/react-i18next.js",
      "^@react-navigation/.*$": "<rootDir>/src/__mocks__/react-navigation.js",
      "^@react-native-async-storage/async-storage$": "<rootDir>/src/__mocks__/@react-native-async-storage/async-storage.js",
      "^../context/AuthContext$": "<rootDir>/src/__mocks__/AuthContext.js",
      "^../services/biometrics$": "<rootDir>/src/__mocks__/biometrics.js",
      "^../components/MilloCoin$": "<rootDir>/src/__mocks__/MilloCoin.js",
      "^expo-local-authentication$": "<rootDir>/src/__mocks__/expo-local-authentication.js",
      "^expo-modules-core$": "<rootDir>/src/__mocks__/expo-modules-core.js",
      "^expo-web-browser$": "<rootDir>/src/__mocks__/expo-web-browser.js",
      "^expo-linking$": "<rootDir>/src/__mocks__/expo-linking.js",
      "^../theme/colors$": "<rootDir>/src/__mocks__/theme-colors.js",
      "^../../theme/colors$": "<rootDir>/src/__mocks__/theme-colors.js",
      "^react-native-safe-area-context$": "<rootDir>/src/__mocks__/react-native-safe-area-context.js",
      "^@expo/vector-icons$": "<rootDir>/src/__mocks__/expo-vector-icons.js",
      "^expo-notifications$": "<rootDir>/src/__mocks__/expo-notifications.js",
      "^@sentry/react-native$": "<rootDir>/src/__mocks__/sentry-react-native.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(expo-local-authentication|expo-modules-core)/)"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "^11.3.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@react-navigation/stack": "^6.4.1",
    "expo": "~51.0.0",
    "expo-constants": "~16.0.2",
    "expo-device": "~6.0.2",
    "expo-linking": "~6.3.1",
    "expo-local-authentication": "~14.0.1",
    "expo-notifications": "~0.28.15",
    "expo-secure-store": "~13.0.2",
    "expo-status-bar": "~1.12.1",
    "expo-web-browser": "~13.0.3",
    "i18next": "^25.8.13",
    "react": "18.2.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.17.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.1",
    "react-native-video": "^6.4.3",
    "@sentry/react-native": "^5.24.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "babel-jest": "^30.2.0",
    "babel-preset-expo": "~11.0.6",
    "jest": "^29.7.0",
    "jest-expo": "^51.0.4"
  }
}