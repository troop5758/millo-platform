{
  "expo": {
    "name": "Millo",
    "slug": "millo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f0f"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.milloapp.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Millo uses Face ID to securely sign you in.",
        "NSCameraUsageDescription": "Millo uses your camera for live streaming.",
        "NSMicrophoneUsageDescription": "Millo uses your microphone for live streaming."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f0f"
      },
      "package": "com.milloapp.mobile",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7c3aed"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://api.milloapp.com",
      "wsUrl": "wss://api.milloapp.com"
    }
  }
}
