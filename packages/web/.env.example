# ─────────────────────────────────────────────────────────────
# Millo Web — environment variables (Vite)
# Copy to .env or .env.local. NEVER commit real secrets.
# Docs: docs/ENV-SETUP-GUIDE.md, docs/SETUP-PRODUCTION.md
# ─────────────────────────────────────────────────────────────

# REQUIRED — API base (no trailing slash). Empty/missing in prod build defaults to https://api.milloapp.com.
# Never fetch relative URLs for API routes — the SPA host returns HTML and breaks JSON clients.
# Development: http://localhost:3000
# Production:    https://api.milloapp.com  (or your API host)
VITE_API_URL=http://localhost:3000

# OPTIONAL — WebSocket URL for live, DMs, auctions
# Leave empty to derive from VITE_API_URL in most hooks (recommended)
VITE_WS_URL=

# Stripe publishable key (pk_test_… / pk_live_…) — required if Stripe Elements / checkout on web
VITE_STRIPE_KEY=pk_test_REPLACE_ME

# OPTIONAL — error tracking
VITE_SENTRY_DSN=

# OPTIONAL — Sift client beacon (Phase 11); pair with API SIFT_API_KEY for server Events API.
VITE_SIFT_BEACON_KEY=

# OPTIONAL — Fingerprint Identification (Pro). When set, web uses @fingerprintjs/fingerprintjs-pro; otherwise open-source agent.
# VITE_FINGERPRINT_PUBLIC_KEY=

# Feature flags — used by nav config (packages/web/src/config/nav.js)
# Set to "true" to show linked surfaces
VITE_ENABLE_ADS=false
VITE_ENABLE_COMPLIANCE=false

# Milla AI creator page (/creator/milla). Overrides config/production-profile.json features.milla when set.
# VITE_FEATURE_MILLA=true | false (omit to use profile)
# VITE_MILLA_ENABLED is deprecated; use features.milla + VITE_FEATURE_MILLA instead.

# OPTIONAL — release label for Sentry
# VITE_APP_VERSION=3.0.0

# -----------------------------------------------------------------------------
# Do NOT add VITE_ENABLE_PUSH / VITE_ENABLE_LIVE / VITE_ENABLE_AI unless the
# codebase reads them. Use nav featureFlag keys only after wiring in nav.js.
# -----------------------------------------------------------------------------
